        "-p",
        "-s",
        "-i",
        "-l",
        "--play",
        "--stop",
        "--info",
        "--list"
      ]
    }
  ],
  "tools/": [],
  "tools/listentogether/": [
    {
      "name": "loop",
      "description": "Loop the track",
      "usage": "loop [option]",
      "options": ["-t", "-f", "--true", "--false"]
    },
    {
      "name": "pause",
      "description": "Pause playing",
      "usage": "pause"
    },
    {
      "name": "play",
      "description": "Strat playing",
      "usage": "play"
    },
    {
      "name": "playlist",
      "description": "Show the playlist",
      "usage": "playlist [options]",
      "options": ["-d", "--detail"]
    },
    {
      "name": "queue",
      "description": "Add a song or playlist to queue",
      "usage": "queue [song_URL|playlist_URL]"
    },
    {
      "name": "random",
      "description": "Random the track",
      "usage": "random [option]",
      "options": ["-t", "-f", "--true", "--false"]
    },
    {
      "name": "rate",
      "description": "Change the playback rate",
      "usage": "rate [value]"
    },
    {
      "name": "refresh",
      "description": "Refresh the queue",
      "usage": "refresh"
    },
    {
      "name": "remove",
      "description": "Remove a track from the queue",
      "usage": "remove [index]"
    },
    {
      "name": "seek",
      "description": "Seek the track",
      "usage": "seek [value]"
    },
    {
      "name": "send",
      "description": "Send the message to the server",
      "usage": "send [message]"
    },
    {
      "name": "switch",
      "description": "Switch the track",
      "usage": "switch [index|option]",
      "options": ["-n", "-p", "--next", "--prev"]
    },
    {
      "name": "volume",
      "description": "Change the volume",
      "usage": "volume [value]"
    }
  ],
  "tools/ytdownloader/": [
    {
      "name": "download",
