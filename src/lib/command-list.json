{
  "*": [
    {
      "name": "cd",
      "description": "Change the directory",
      "usage": "cd [directory]"
    },
    {
      "name": "cl",
      "description": "Clear the console",
      "usage": "cl"
    },
    {
      "name": "help",
      "description": "Show the help message",
      "usage": "help [command]"
    },
    {
      "name": "log",
      "description": "Show the log message",
      "usage": "log [message]"
    },
    {
      "name": "ls",
      "description": "List the directory",
      "usage": "ls",
      "options": ["-a", "-l", "-t", "--all", "--long", "--tree"]
    },
    {
      "name": "background",
      "description": "Change the background",
      "usage": "background [image_URL]"
    },
    {
      "name": "backgroundcolor",
      "description": "Change the background color",
      "usage": "backgroundcolor [color]"
    },
    {
      "name": "username",
      "description": "Set your username",
      "usage": "username [name]"
    }
  ],
  "/": [
    {
      "name": "github",
      "description": "Open my GitHub profile",
      "usage": "github"
    },
    {
      "name": "youtube",
      "description": "Open my YouTube channel",
      "usage": "youtube"
    },
    {
      "name": "twitter",
      "description": "Open my Twitter channel",
      "usage": "twitter"
    },
    {
      "name": "instagram",
      "description": "Open my Instagram profile",
      "usage": "instagram"
    },
    {
      "name": "twitch",
      "description": "Open my Twitch profile",
      "usage": "twitch"
    },
    {
      "name": "discord",
      "description": "Add me on Discord",
      "usage": "discord"
    },
    {
      "name": "email",
      "description": "Send me an email",
      "usage": "email"
    },
    {
      "name": "osu",
      "description": "Open my osu! profile",
      "usage": "osu"
    },
    {
      "name": "music",
      "description": "Background music options",
